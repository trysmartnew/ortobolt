# ── OrtoBolt Environment Variables ────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA faça commit do .env.local — ele está no .gitignore.

# ── FRONTEND (prefixo VITE_ — incluído no bundle do cliente) ──────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxx

# ── BACKEND (sem prefixo VITE_ — APENAS no servidor / Vercel Functions) ─────
# GEMINI_API_KEY=...                    # Google AI — proxy /api/ai
# SUPABASE_URL=https://xxxxx.supabase.co   # mesmo valor de VITE_SUPABASE_URL
# SUPABASE_ANON_KEY=eyJxxxxx               # mesmo valor de VITE_SUPABASE_ANON_KEY
# (fallback: VITE_SUPABASE_* também é lido em api/ai se SUPABASE_* não existir)
