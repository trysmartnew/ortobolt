# ── OrtoBolt Environment Variables ────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA faça commit do .env.local — ele está no .gitignore.

# ── FRONTEND (prefixo VITE_ — incluído no bundle do cliente) ──────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxx

# ── BACKEND (sem prefixo VITE_ — APENAS no servidor) ─────────────────────────
# ❌ NÃO usar VITE_OPENROUTER_API_KEY — a chave ficaria exposta no bundle!
# ✅ Configurar no painel Vercel → Settings → Environment Variables:
#    Nome:  OPENROUTER_API_KEY
#    Valor: sk-or-v1-xxxxxxxxxxxx
#    Escopo: Production + Preview + Development
#
# Para desenvolvimento local, adicionar em .env.local (sem VITE_):
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
#
# Obtenha sua chave em: https://openrouter.ai/keys
# Modelo configurado:   qwen/qwen3-vl-235b-a22b-thinking
